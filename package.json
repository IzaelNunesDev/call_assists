{
  "name": "call-assists",
  "version": "1.0.0",
  "private": true,
  "description": "Assistente de IA para Reuniões - Invisível no Screen Share",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c cyan,magenta \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "start": "electron .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@google/genai": "^1.48.0",
    "extract-zip": "^2.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  }
}
